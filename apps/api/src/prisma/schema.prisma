generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // or "mysql" if you use MySQL
  url      = env("DATABASE_URL")
}

//
// ─── ENUMS ────────────────────────────────────────────────
//
enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum TrackStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED_SCHEDULED
  PUBLISHED
  REJECTED
  WITHDRAWN
}

enum PlaylistVisibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

enum AnnouncementVisibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

//
// ─── USER & ROLE ─────────────────────────────────────────
//
model User {
  id          String     @id @default(uuid())
  email       String     @unique
  password    String
  displayName String
  avatarUrl   String?
  status      UserStatus @default(ACTIVE)
  locale      String?
  timezone    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  roles         UserRole[]
  artist        Artist?
  playlists     Playlist[]
  follows       ArtistFollow[]          @relation("UserFollowsArtist")
  followers     UserFollow[]            @relation("UserFollowsUserFollower")
  following     UserFollow[]            @relation("UserFollowsUserFollowing")
  presaves      PreSave[]
  likes         TrackLike[]
  saved         SavedTrack[]
  listens       Listen[]
  comments      Comment[]
  notifPrefs    NotificationPreference?
  notifications Notification[]
  PlaylistItem  PlaylistItem[]
}

model Role {
  code  String     @id
  name  String
  users UserRole[]
}

model UserRole {
  userId   String
  roleCode String

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleCode], references: [code])

  @@id([userId, roleCode])
}

//
// ─── ARTIST ──────────────────────────────────────────────
//
model Artist {
  id        String  @id @default(uuid())
  userId    String  @unique
  stageName String
  verified  Boolean @default(false)
  bio       String?
  links     Json?
  timezone  String?

  user          User           @relation(fields: [userId], references: [id])
  tracks        Track[]
  followers     ArtistFollow[]
  announcements Announcement[]
}

model ArtistFollow {
  id         String   @id @default(uuid())
  followerId String
  artistId   String
  createdAt  DateTime @default(now())

  follower User   @relation("UserFollowsArtist", fields: [followerId], references: [id])
  artist   Artist @relation(fields: [artistId], references: [id])

  @@unique([followerId, artistId])
}

model UserFollow {
  id         String   @id @default(uuid())
  followerId String
  followeeId String
  createdAt  DateTime @default(now())

  follower User @relation("UserFollowsUserFollower", fields: [followerId], references: [id])
  followee User @relation("UserFollowsUserFollowing", fields: [followeeId], references: [id])

  @@unique([followerId, followeeId])
}

//
// ─── ASSETS & TRACK ──────────────────────────────────────
//
model Asset {
  id         String   @id @default(uuid())
  kind       String
  storageUrl String
  mimeType   String?
  durationMs Int?
  width      Int?
  height     Int?
  checksum   String?
  createdAt  DateTime @default(now())

  audioTracks Track[] @relation("TrackAudio")
  coverTracks Track[] @relation("TrackCover")
}

model Track {
  id           String      @id @default(uuid())
  artistId     String
  title        String
  description  String?
  isExplicit   Boolean     @default(false)
  durationMs   Int?
  status       TrackStatus @default(DRAFT)
  releaseAt    DateTime?
  audioAssetId String
  coverAssetId String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  artist       Artist         @relation(fields: [artistId], references: [id])
  audioAsset   Asset          @relation("TrackAudio", fields: [audioAssetId], references: [id])
  coverAsset   Asset          @relation("TrackCover", fields: [coverAssetId], references: [id])
  likes        TrackLike[]
  savedBy      SavedTrack[]
  presaves     PreSave[]
  listens      Listen[]
  comments     Comment[]
  PlaylistItem PlaylistItem[]
}

//
// ─── PLAYLIST ────────────────────────────────────────────
//
model Playlist {
  id          String             @id @default(uuid())
  ownerId     String
  name        String
  visibility  PlaylistVisibility @default(PUBLIC)
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  owner User           @relation(fields: [ownerId], references: [id])
  items PlaylistItem[]
}

model PlaylistItem {
  id         String   @id @default(uuid())
  playlistId String
  trackId    String
  position   Int
  addedBy    String
  addedAt    DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id])
  track    Track    @relation(fields: [trackId], references: [id])
  user     User     @relation(fields: [addedBy], references: [id])
}

//
// ─── ANNOUNCEMENTS ───────────────────────────────────────
//
model Announcement {
  id          String                 @id @default(uuid())
  artistId    String
  title       String
  body        String
  visibility  AnnouncementVisibility @default(PUBLIC)
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime               @default(now())

  artist   Artist    @relation(fields: [artistId], references: [id])
  comments Comment[]
}

//
// ─── USER INTERACTIONS ───────────────────────────────────
//
model PreSave {
  id        String   @id @default(uuid())
  userId    String
  trackId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  track Track @relation(fields: [trackId], references: [id])

  @@unique([userId, trackId])
}

model TrackLike {
  id        String   @id @default(uuid())
  userId    String
  trackId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  track Track @relation(fields: [trackId], references: [id])

  @@unique([userId, trackId])
}

model SavedTrack {
  id        String   @id @default(uuid())
  userId    String
  trackId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  track Track @relation(fields: [trackId], references: [id])

  @@unique([userId, trackId])
}

model Listen {
  id         String   @id @default(uuid())
  userId     String?
  trackId    String
  startedAt  DateTime @default(now())
  listenedMs Int?
  completed  Boolean  @default(false)

  user  User? @relation(fields: [userId], references: [id])
  track Track @relation(fields: [trackId], references: [id])
}

model Comment {
  id             String   @id @default(uuid())
  userId         String
  trackId        String?
  announcementId String?
  parentId       String?
  body           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  track        Track?        @relation(fields: [trackId], references: [id])
  announcement Announcement? @relation(fields: [announcementId], references: [id])
  parent       Comment?      @relation("CommentThread", fields: [parentId], references: [id])
  children     Comment[]     @relation("CommentThread")
}

//
// ─── NOTIFICATIONS ───────────────────────────────────────
//
model NotificationPreference {
  userId     String  @id
  inApp      Boolean @default(true)
  push       Boolean @default(true)
  email      Boolean @default(true)
  quietHours Json?
  typesOptIn Json?

  user User @relation(fields: [userId], references: [id])
}

model Notification {
  id          String    @id @default(uuid())
  userId      String
  type        String
  channel     String
  status      String    @default("queued")
  payload     Json?
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}
